<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:id="rootPane" fx:controller="com.notegraph.controller.MainController" prefHeight="700.0" prefWidth="1200.0">
    <top>
        <VBox>
            <MenuBar>
                <Menu text="Файл">
                    <MenuItem text="Новая заметка" onAction="#handleNewNote" accelerator="Ctrl+N"/>
                    <MenuItem text="Ежедневная заметка" onAction="#handleDailyNote" accelerator="Ctrl+D"/>
                    <MenuItem text="Новая папка" onAction="#handleNewFolder" accelerator="Ctrl+Shift+N"/>
                    <MenuItem text="Сохранить" onAction="#handleSave" accelerator="Ctrl+S"/>
                    <SeparatorMenuItem/>
                    <MenuItem text="Выход" onAction="#handleExit" accelerator="Ctrl+Q"/>
                </Menu>
                <Menu text="Правка">
                    <MenuItem text="Вырезать" onAction="#handleCut" accelerator="Ctrl+X"/>
                    <MenuItem text="Вставить" onAction="#handlePaste" accelerator="Ctrl+V"/>
                    <MenuItem text="Удалить" onAction="#handleDelete" accelerator="Delete"/>
                </Menu>
                <Menu text="Поиск">
                    <MenuItem text="Найти" onAction="#handleSearch" accelerator="Ctrl+F"/>
                </Menu>
                <Menu text="Вид">
                    <MenuItem text="Переключить тему" onAction="#handleToggleTheme" accelerator="Ctrl+T"/>
                </Menu>
                <Menu text="Граф">
                    <MenuItem text="Открыть граф заметок" onAction="#handleOpenGraph"/>
                </Menu>
            </MenuBar>
            <ToolBar>
                <Button text="Новая заметка" onAction="#handleNewNote"/>
                <Button text="Сегодня" onAction="#handleDailyNote" style="-fx-font-size: 12px; -fx-background-color: #4CAF50; -fx-text-fill: white;"/>
                <Separator orientation="VERTICAL"/>
                <Label text="Поиск:"/>
                <TextField fx:id="searchField" promptText="Поиск..." prefWidth="200"/>
                <Button text="Найти" onAction="#handleSearch"/>
            </ToolBar>
        </VBox>
    </top>
    <center>
        <SplitPane dividerPositions="0.25">
            <VBox>
                <padding>
                    <Insets top="10" right="10" bottom="10" left="10"/>
                </padding>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="Заметки" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
                    <Label fx:id="notesCountLabel" text="Заметок: 0" style="-fx-text-fill: gray;"/>
                </HBox>
                <TreeView fx:id="notesTreeView" VBox.vgrow="ALWAYS"/>
            </VBox>
            <StackPane>
                <VBox fx:id="placeholderPane" alignment="CENTER" spacing="20" visible="true">
                    <Label text="Выберите заметку или создайте новую" style="-fx-font-size: 16px; -fx-text-fill: gray;"/>
                    <HBox spacing="10" alignment="CENTER">
                        <Button text="+ Создать заметку" onAction="#handleNewNote" style="-fx-font-size: 14px;"/>
                        <Button text="Ежедневная заметка" onAction="#handleDailyNote" style="-fx-font-size: 14px; -fx-background-color: #4CAF50; -fx-text-fill: white;"/>
                    </HBox>
                </VBox>
                <TabPane fx:id="notesTabPane" visible="false" tabClosingPolicy="ALL_TABS"/>
            </StackPane>
        </SplitPane>
    </center>
    <bottom>
        <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-padding: 5;">
            <Label text="NoteGraph"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="autoSaveLabel" text="✓ Сохранено" visible="false" style="-fx-text-fill: green;"/>
        </HBox>
    </bottom>
</BorderPane>