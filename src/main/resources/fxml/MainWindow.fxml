<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:id="rootPane"
            fx:controller="com.notegraph.controller.MainController"
            prefHeight="700.0"
            prefWidth="1200.0">

    <top>
        <VBox>
            <HBox fx:id="titleBar"
                  style="-fx-background-color: -fx-background;"
                  alignment="CENTER_LEFT"
                  spacing="10"
                  prefHeight="30">

                <Label text="NoteGraph" />

                <Pane HBox.hgrow="ALWAYS"/>

                <Button text="—" onAction="#handleMinimize"/>
                <Button text="□" onAction="#handleMaximize"/>
                <Button text="X" onAction="#handleClose"/>
            </HBox>
            <MenuBar>
                <Menu text="%menu.file">
                    <MenuItem text="%file.newNote" onAction="#handleNewNote" accelerator="Ctrl+N"/>
                    <MenuItem text="%file.dailyNote" onAction="#handleDailyNote" accelerator="Ctrl+D"/>
                    <MenuItem text="%file.newFolder" onAction="#handleNewFolder" accelerator="Ctrl+Shift+N"/>
                    <MenuItem text="%file.save" onAction="#handleSave" accelerator="Ctrl+S"/>
                    <SeparatorMenuItem/>
                    <MenuItem text="%file.exit" onAction="#handleExit" accelerator="Ctrl+Q"/>
                </Menu>

                <Menu text="%menu.edit">
                    <MenuItem text="%edit.cut" onAction="#handleCut" accelerator="Ctrl+X"/>
                    <MenuItem text="%edit.paste" onAction="#handlePaste" accelerator="Ctrl+V"/>
                    <MenuItem text="%edit.delete" onAction="#handleDelete" accelerator="Delete"/>
                </Menu>

                <Menu text="%menu.search">
                    <MenuItem text="%search.find" onAction="#handleSearch" accelerator="Ctrl+F"/>
                </Menu>

                <Menu text="%menu.view">
                    <MenuItem text="%view.theme" onAction="#handleToggleTheme" accelerator="Ctrl+T"/>
                    <MenuItem text="%view.font" onAction="#handleFontSettings" accelerator="Ctrl+Shift+F"/>
                </Menu>

                <Menu text="%menu.graph">
                    <MenuItem text="%graph.open" onAction="#handleOpenGraph"/>
                </Menu>

                <Menu text="%menu.language">
                    <MenuItem text="Русский" onAction="#switchToRussian"/>
                    <MenuItem text="English" onAction="#switchToEnglish"/>
                </Menu>
            </MenuBar>

            <ToolBar>

                <Button onAction="#handleNewNote">
                    <tooltip>
                        <Tooltip text="%toolbar.newNote"/>
                    </tooltip>
                    <graphic>
                        <ImageView fitWidth="16" fitHeight="16">
                            <image>
                                <Image url="@/icons/new-note.png"/>
                            </image>
                        </ImageView>
                    </graphic>
                </Button>

                <Button onAction="#handleDailyNote">
                    <tooltip>
                        <Tooltip text="%toolbar.today"/>
                    </tooltip>
                    <graphic>
                        <ImageView fitWidth="16" fitHeight="16">
                            <image>
                                <Image url="@/icons/today.png"/>
                            </image>
                        </ImageView>
                    </graphic>
                </Button>

                <Button onAction="#handleOpenNotesFolder">
                    <tooltip>
                        <Tooltip text="%toolbar.openFolder"/>
                    </tooltip>
                    <graphic>
                        <ImageView fitWidth="16" fitHeight="16">
                            <image>
                                <Image url="@/icons/root-folder.png"/>
                            </image>
                        </ImageView>
                    </graphic>
                </Button>

                <Separator orientation="VERTICAL"/>

                <Label text="%toolbar.search"/>

                <TextField fx:id="searchField"
                           promptText="%toolbar.searchPrompt"
                           prefWidth="200"/>

                <Button onAction="#handleSearch">
                    <tooltip>
                        <Tooltip text="%toolbar.find"/>
                    </tooltip>
                    <graphic>
                        <ImageView fitWidth="16" fitHeight="16">
                            <image>
                                <Image url="@/icons/search.png"/>
                            </image>
                        </ImageView>
                    </graphic>
                </Button>

                <Separator orientation="VERTICAL"/>

                <Label text="%toolbar.sort"/>

                <ComboBox fx:id="sortComboBox" prefWidth="180"/>

            </ToolBar>

        </VBox>
    </top>

    <center>
        <SplitPane dividerPositions="0.25">

            <VBox>
                <padding>
                    <Insets top="10" right="10" bottom="10" left="10"/>
                </padding>

                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="%notes.title" style="-fx-font-weight: bold;"/>
                    <Label fx:id="notesCountLabel"
                           text="%notes.count"
                           style="-fx-text-fill: gray;"/>
                </HBox>

                <TreeView fx:id="notesTreeView" VBox.vgrow="ALWAYS"/>
            </VBox>

            <StackPane>

                <VBox fx:id="placeholderPane"
                      alignment="CENTER"
                      spacing="20"
                      visible="true">

                    <Label text="%placeholder.text"
                           style="-fx-text-fill: gray;"/>

                    <HBox spacing="10" alignment="CENTER">
                        <Button text="%placeholder.newNote" onAction="#handleNewNote"/>
                        <Button text="%placeholder.dailyNote" onAction="#handleDailyNote"/>
                    </HBox>
                </VBox>

                <TabPane fx:id="notesTabPane"
                         visible="false"
                         tabClosingPolicy="ALL_TABS"/>

            </StackPane>

        </SplitPane>
    </center>

    <bottom>
        <HBox spacing="10"
              alignment="CENTER_LEFT"
              style="-fx-padding: 5;">

            <Label text="%app.name"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Label fx:id="autoSaveLabel"
                   text="%status.saved"
                   visible="false"
                   style="-fx-text-fill: green;"/>
        </HBox>
    </bottom>

</BorderPane>